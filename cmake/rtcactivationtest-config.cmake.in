# RTCActivationTest CMake config file
#
# This file sets the following variables:
# RTCActivationTest_FOUND - Always TRUE.
# RTCActivationTest_INCLUDE_DIRS - Directories containing the RTCActivationTest include files.
# RTCActivationTest_IDL_DIRS - Directories containing the RTCActivationTest IDL files.
# RTCActivationTest_LIBRARIES - Libraries needed to use RTCActivationTest.
# RTCActivationTest_DEFINITIONS - Compiler flags for RTCActivationTest.
# RTCActivationTest_VERSION - The version of RTCActivationTest found.
# RTCActivationTest_VERSION_MAJOR - The major version of RTCActivationTest found.
# RTCActivationTest_VERSION_MINOR - The minor version of RTCActivationTest found.
# RTCActivationTest_VERSION_REVISION - The revision version of RTCActivationTest found.
# RTCActivationTest_VERSION_CANDIDATE - The candidate version of RTCActivationTest found.

message(STATUS "Found RTCActivationTest-@PROJECT_VERSION@")
set(RTCActivationTest_FOUND TRUE)

find_package(<dependency> REQUIRED)

#set(RTCActivationTest_INCLUDE_DIRS
#    "@CMAKE_INSTALL_PREFIX@/include/@PROJECT_NAME_LOWER@-@PROJECT_VERSION_MAJOR@"
#    ${<dependency>_INCLUDE_DIRS}
#    )
#
#set(RTCActivationTest_IDL_DIRS
#    "@CMAKE_INSTALL_PREFIX@/include/@PROJECT_NAME_LOWER@-@PROJECT_VERSION_MAJOR@/idl")
set(RTCActivationTest_INCLUDE_DIRS
    "@CMAKE_INSTALL_PREFIX@/include/@CPACK_PACKAGE_FILE_NAME@"
    ${<dependency>_INCLUDE_DIRS}
    )
set(RTCActivationTest_IDL_DIRS
    "@CMAKE_INSTALL_PREFIX@/include/@CPACK_PACKAGE_FILE_NAME@/idl")


if(WIN32)
    set(RTCActivationTest_LIBRARIES
        "@CMAKE_INSTALL_PREFIX@/@LIB_INSTALL_DIR@/@CMAKE_SHARED_LIBRARY_PREFIX@@PROJECT_NAME_LOWER@@CMAKE_STATIC_LIBRARY_SUFFIX@"
        ${<dependency>_LIBRARIES}
        )
else(WIN32)
    set(RTCActivationTest_LIBRARIES
        "@CMAKE_INSTALL_PREFIX@/@LIB_INSTALL_DIR@/@CMAKE_SHARED_LIBRARY_PREFIX@@PROJECT_NAME_LOWER@@CMAKE_SHARED_LIBRARY_SUFFIX@"
        ${<dependency>_LIBRARIES}
        )
endif(WIN32)

set(RTCActivationTest_DEFINITIONS ${<dependency>_DEFINITIONS})

set(RTCActivationTest_VERSION @PROJECT_VERSION@)
set(RTCActivationTest_VERSION_MAJOR @PROJECT_VERSION_MAJOR@)
set(RTCActivationTest_VERSION_MINOR @PROJECT_VERSION_MINOR@)
set(RTCActivationTest_VERSION_REVISION @PROJECT_VERSION_REVISION@)
set(RTCActivationTest_VERSION_CANDIDATE @PROJECT_VERSION_CANDIDATE@)

